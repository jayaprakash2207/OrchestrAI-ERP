# Global
PROJECT_NAME=AI ERP Platform
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_SQL_QUERIES=false

# Security
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Platform PostgreSQL
POSTGRES_DB=ai_erp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/ai_erp
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_CONNECT_TIMEOUT=10
DB_RETRY_ATTEMPTS=5
DB_RETRY_MIN_WAIT_SECONDS=1
DB_RETRY_MAX_WAIT_SECONDS=10
DB_STARTUP_CHECK_ENABLED=true
DB_STATEMENT_TIMEOUT_MS=30000

# Vector Store
CHROMA_HOST=chromadb
CHROMA_PORT=8001
CHROMA_COLLECTION_PREFIX=ai_erp
CHROMA_JDE_COLLECTION_NAME=jde_knowledge
CHROMA_HEALTHCHECK_TIMEOUT_SECONDS=5
CHROMA_RETRIEVAL_LIMIT=5
CHROMA_SIMILARITY_THRESHOLD=0.2

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_OUTPUT_TOKENS=4096
GEMINI_HEALTHCHECK_TIMEOUT_SECONDS=5
GEMINI_REASONING_MAX_TOKENS=2000
GEMINI_CODE_MAX_TOKENS=8000
GEMINI_RETRY_ATTEMPTS=3
GEMINI_DAILY_TOKEN_BUDGET=500000
GEMINI_MONTHLY_TOKEN_BUDGET=10000000
GEMINI_COST_PER_1K_INPUT_TOKENS=0.00015
GEMINI_COST_PER_1K_OUTPUT_TOKENS=0.0006
LLM_CACHE_TTL_SECONDS=86400
RETRIEVAL_CACHE_TTL_SECONDS=86400

# JD Edwards Connectivity
JDE_CONNECTION_MODE=api

# JD Edwards API Option
JDE_API_BASE_URL=https://jde.example.com/jderest
JDE_API_USERNAME=
JDE_API_PASSWORD=
JDE_API_TOKEN=
JDE_OAUTH_CLIENT_ID=
JDE_OAUTH_CLIENT_SECRET=
JDE_OAUTH_TOKEN_URL=https://jde.example.com/oauth2/token
JDE_API_TIMEOUT_SECONDS=30

# JD Edwards Database Option
JDE_DATABASE_URL=
JDE_DATABASE_USER=
JDE_DATABASE_PASSWORD=
JDE_ENVIRONMENT=DV920
JDE_ROLE=*ALL
JDE_DB_QUERY_TIMEOUT_SECONDS=30
JDE_CACHE_VENDOR_TTL_SECONDS=3600
JDE_CACHE_CUSTOMER_TTL_SECONDS=3600
JDE_CACHE_GL_TTL_SECONDS=86400
JDE_CACHE_VOLATILE_TTL_SECONDS=300

# LangGraph
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ai-erp-platform
STATE_STORAGE_PATH=data/state

# Feature Flags
FEATURE_AUTOERP_ENABLED=true
FEATURE_JDE_COPILOT_ENABLED=true
FEATURE_JDE_API_INGESTION_ENABLED=true
FEATURE_JDE_DATABASE_INGESTION_ENABLED=false
FEATURE_LANGGRAPH_TRACING_ENABLED=false
MOCK_LLM_MODE=false
GEMINI_FALLBACK_TO_MOCK=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=30

# Finance Defaults
FINANCE_AP_APPROVAL_THRESHOLD=10000
FINANCE_AP_PAYABLE_ACCOUNT_NUMBER=2000
FINANCE_CASH_ACCOUNT_NUMBER=1000

# Redis
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=AI ERP Platform
